{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Market Research Output",
  "description": "Legacy research report sidecar. Deterministic research bundles are specified by deterministic-bundle.schema.json.",
  "type": "object",
  "required": [
    "symbol",
    "security_type",
    "as_of_date",
    "material_claims",
    "data_gaps",
    "technical_analysis",
    "valuation_or_performance",
    "decision_factors",
    "risks",
    "catalysts",
    "source_coverage",
    "calculation_audit"
  ],
  "properties": {
    "symbol": {
      "type": "string"
    },
    "security_type": {
      "enum": ["equity", "adr", "etf"]
    },
    "as_of_date": {
      "type": "string"
    },
    "material_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "source_id", "confidence"],
        "properties": {
          "claim": {
            "type": "string"
          },
          "source_id": {
            "type": "string"
          },
          "source_date": {
            "type": ["string", "null"]
          },
          "accessed_date": {
            "type": ["string", "null"]
          },
          "confidence": {
            "enum": ["high", "medium", "low", "unverified"]
          },
          "verification_status": {
            "enum": ["verified", "unverified", "data_not_available"]
          }
        },
        "additionalProperties": true
      }
    },
    "data_gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/data_gap"
      }
    },
    "technical_analysis": {
      "type": "object",
      "additionalProperties": true
    },
    "valuation_or_performance": {
      "type": "object",
      "additionalProperties": true
    },
    "decision_factors": {
      "type": "object",
      "additionalProperties": true
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "catalysts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "source_coverage": {
      "type": "object",
      "additionalProperties": true
    },
    "calculation_audit": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "deterministic_bundle": {
      "type": "object",
      "description": "Optional pointer to a deterministic data bundle generated by scripts/deterministic_research_collector.py.",
      "required": ["bundle_dir", "manifest", "source_manifest", "gaps", "research_input_pack"],
      "properties": {
        "bundle_dir": {"type": "string"},
        "manifest": {"type": "string"},
        "source_manifest": {"type": "string"},
        "gaps": {"type": "string"},
        "research_input_pack": {"type": "string"}
      },
      "additionalProperties": true
    },
    "deterministic_data_usage": {
      "type": "array",
      "description": "Field-level disposition for deterministic_data_usage.json datapoints marked required or review.",
      "items": {
        "type": "object",
        "required": ["field_path", "disposition", "rationale"],
        "properties": {
          "field_path": {"type": "string"},
          "materiality": {"enum": ["required", "review", "context"]},
          "disposition": {"enum": ["used", "intentionally_omitted_not_material", "duplicated_by_better_source", "stale_or_wrong_entity", "unusable"]},
          "rationale": {"type": "string"},
          "report_section": {"type": "string"},
          "source_artifact": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "data_gap": {
      "type": "object",
      "required": ["field", "status"],
      "properties": {
        "field": {"type": "string"},
        "status": {"type": "string"},
        "attempted_sources": {"type": "array", "items": {"type": "string"}},
        "notes": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
