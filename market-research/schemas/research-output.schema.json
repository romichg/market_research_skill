{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Market Research Output",
  "description": "Legacy research report sidecar. Deterministic research bundles are specified by deterministic-bundle.schema.json.",
  "type": "object",
  "required": ["symbol", "security_type", "material_claims", "data_gaps"],
  "properties": {
    "symbol": {
      "type": "string"
    },
    "security_type": {
      "enum": ["equity", "adr", "etf"]
    },
    "as_of_date": {
      "type": "string"
    },
    "material_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "source_id", "confidence"],
        "properties": {
          "claim": {
            "type": "string"
          },
          "source_id": {
            "type": "string"
          },
          "source_date": {
            "type": ["string", "null"]
          },
          "accessed_date": {
            "type": ["string", "null"]
          },
          "confidence": {
            "enum": ["high", "medium", "low", "unverified"]
          },
          "verification_status": {
            "enum": ["verified", "unverified", "data_not_available"]
          }
        },
        "additionalProperties": true
      }
    },
    "data_gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/data_gap"
      }
    },
    "deterministic_bundle": {
      "type": "object",
      "description": "Optional pointer to a deterministic data bundle generated by scripts/research_data.py.",
      "required": ["bundle_dir", "manifest", "source_manifest", "gaps", "research_input_pack"],
      "properties": {
        "bundle_dir": {"type": "string"},
        "manifest": {"type": "string"},
        "source_manifest": {"type": "string"},
        "gaps": {"type": "string"},
        "research_input_pack": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "data_gap": {
      "type": "object",
      "required": ["field", "status"],
      "properties": {
        "field": {"type": "string"},
        "status": {"type": "string"},
        "attempted_sources": {"type": "array", "items": {"type": "string"}},
        "notes": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
