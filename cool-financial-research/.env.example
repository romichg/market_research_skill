# Required
OPENAI_API_KEY=sk-...

# Optional model overrides
CFR_ORCHESTRATOR_MODEL=gpt-5.5
CFR_RESEARCH_MODEL=gpt-5.5-pro
CFR_VALIDATION_MODEL=gpt-5.5-pro
CFR_FIX_MODEL=gpt-5.5-pro
