{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/openclaw/cool-financial-research/research-output.schema.json",
  "title": "ResearchOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "symbol",
    "security_type",
    "stage",
    "iteration",
    "markdown_report",
    "structured_data"
  ],
  "properties": {
    "symbol": {
      "type": "string",
      "pattern": "^[A-Z0-9.\\-]{1,12}$"
    },
    "security_type": {
      "type": "string",
      "enum": [
        "equity",
        "adr",
        "etf"
      ]
    },
    "stage": {
      "type": "string",
      "enum": [
        "research",
        "fix",
        "final"
      ]
    },
    "iteration": {
      "type": "integer",
      "minimum": 0
    },
    "markdown_report": {
      "type": "string"
    },
    "structured_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbol",
        "security_type",
        "analysis_date",
        "summary",
        "quality_control",
        "sections",
        "sources",
        "open_questions",
        "unresolved_issues"
      ],
      "properties": {
        "symbol": {
          "type": "string"
        },
        "security_type": {
          "type": "string",
          "enum": [
            "equity",
            "adr",
            "etf"
          ]
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "exchange": {
          "type": [
            "string",
            "null"
          ]
        },
        "analysis_date": {
          "type": "string"
        },
        "recommendation": {
          "type": [
            "string",
            "null"
          ]
        },
        "conviction": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "low",
            "medium",
            "high",
            "unverified",
            null
          ]
        },
        "summary": {
          "type": "string"
        },
        "quality_control": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "primary_sources_preferred",
            "facts_interpretation_separated",
            "quant_claims_sourced_or_marked_unverified",
            "stale_data_flagged"
          ],
          "properties": {
            "primary_sources_preferred": {
              "type": "boolean"
            },
            "facts_interpretation_separated": {
              "type": "boolean"
            },
            "quant_claims_sourced_or_marked_unverified": {
              "type": "boolean"
            },
            "stale_data_flagged": {
              "type": "boolean"
            },
            "notes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "sections": {
          "type": "array",
          "minItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "number",
              "title",
              "facts",
              "interpretation",
              "quantitative_claims",
              "sources",
              "open_questions"
            ],
            "properties": {
              "number": {
                "type": "integer",
                "minimum": 1,
                "maximum": 16
              },
              "title": {
                "type": "string"
              },
              "facts": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "interpretation": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "quantitative_claims": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/quantitative_claim"
                }
              },
              "sources": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/source"
                }
              },
              "open_questions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source"
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unresolved_issues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/unresolved_issue"
          }
        },
        "data_quality_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fix_response": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "validation_iteration",
            "addressed_issues"
          ],
          "properties": {
            "validation_iteration": {
              "type": "integer",
              "minimum": 1
            },
            "addressed_issues": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/fix_response_item"
              }
            }
          }
        },
        "paid_data_recommendations": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "service",
              "reason",
              "related_data_gap_categories",
              "confidence"
            ],
            "properties": {
              "service": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "related_data_gap_categories": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low",
                  "unverified"
                ]
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "quantitative_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_text",
        "source_id",
        "confidence",
        "verification_status",
        "stale"
      ],
      "properties": {
        "claim_text": {
          "type": "string"
        },
        "value": {
          "type": [
            "string",
            "number",
            "null"
          ]
        },
        "as_of_date": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_date": {
          "type": [
            "string",
            "null"
          ]
        },
        "accessed_date": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "unverified"
          ]
        },
        "verification_status": {
          "type": "string",
          "enum": [
            "verified_primary",
            "verified_secondary",
            "unverified",
            "not_available"
          ]
        },
        "stale": {
          "type": "boolean"
        },
        "staleness_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "fact_or_interpretation": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "fact",
            "interpretation",
            null
          ]
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "confidence"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        },
        "document_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "publication_date": {
          "type": [
            "string",
            "null"
          ]
        },
        "accessed_date": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "unverified"
          ]
        },
        "primary_or_secondary": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "primary",
            "secondary",
            "paid_licensed",
            "unverified",
            null
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "unresolved_issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "severity",
        "section",
        "issue",
        "status",
        "reason"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "critical",
            "moderate",
            "minor"
          ]
        },
        "section": {
          "type": "string"
        },
        "issue": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "const": "unresolved_data_unavailable"
        },
        "reason": {
          "type": "string"
        },
        "recommended_next_step": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "fix_response_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issue_id",
        "status",
        "explanation"
      ],
      "properties": {
        "issue_id": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "fixed",
            "unresolved_data_unavailable"
          ]
        },
        "explanation": {
          "type": "string"
        },
        "source_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}